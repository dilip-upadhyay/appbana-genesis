{
  "name": "appbana-genesis",
  "version": "0.0.0",
  "private": true,
  "description": "AI-native enterprise application creation platform — from business intent to enterprise application.",
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "test": "pnpm -r --if-present run test",
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "validate:schemas": "pnpm --filter @appbana/validate-schemas run validate",
    "clean": "pnpm -r --if-present run clean && rimraf node_modules"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  },
  "license": "UNLICENSED"
}
